{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Ocelot": {
    "Routes": [
      {
        "DownstreamPathTemplate": "/api/v1/slider/{everything}",
        "DownstreamScheme": "http",
        "DownstreamHostAndPorts": [
          {
            "Host": "localhost",
            "Port": 8081
          }
        ],
        "UpstreamPathTemplate": "/api/slider/{everything}",
        "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ]
      },
      {
        "DownstreamPathTemplate": "/api/v1/slider",
        "DownstreamScheme": "http",
        "DownstreamHostAndPorts": [
          {
            "Host": "localhost",
            "Port": 8081
          }
        ],
        "UpstreamPathTemplate": "/",
        "UpstreamHttpMethod": [ "GET" ]
      }
    ]
  }
}
